{
  "model": {
    "hidden_size": 2048,
    "num_hidden_layers": 22,
    "num_attention_heads": 32,
    "num_key_value_heads": 4,
    "intermediate_size": 5504,
    "vocab_size": 256000,
    "max_position_embeddings": 4096,
    "rms_norm_eps": 1e-06,
    "rope_theta": 500000.0
  },
  "training": {
    "data_dir": "taiji_data/training_data",
    "tokenizer_dir": "taiji/tokenizer_native_v2",
    "tokenizer_path": "taiji/tokenizer_native_v2/sentencepiece.model",
    "contract_path": "taiji/tokenizer_native_v2/tokenizer_contract.json",
    "output_dir": "taiji_checkpoints/taiji_1b",
    "holdout_dir": "taiji_data/training_data/pretrain_12b/holdout",
    "max_steps": 200000,
    "batch_size": 1,
    "gradient_accumulation_steps": 64,
    "learning_rate": 0.0003,
    "min_learning_rate": 3e-05,
    "warmup_steps": 1000,
    "max_length": 2048,
    "save_every": 5000,
    "log_every": 50,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "use_amp": false,
    "use_streaming": true,
    "streaming_buffer": 10000,
    "gradient_checkpointing": false,
    "num_workers": 2,
    "seed": 42,
    "keep_last_checkpoints": 3,
    "category_weights": {
      "english": 0.30,
      "chinese": 0.25,
      "code": 0.15,
      "math": 0.12,
      "wikipedia": 0.08,
      "taiji": 0.05,
      "replay": 0.05
    }
  }
}
