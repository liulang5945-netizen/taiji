{
  "model": {
    "hidden_size": 1024,
    "num_hidden_layers": 24,
    "num_attention_heads": 16,
    "num_key_value_heads": 16,
    "intermediate_size": 2816,
    "vocab_size": 256000,
    "max_position_embeddings": 2048,
    "rms_norm_eps": 1e-6,
    "rope_theta": 1000000.0
  },
  "training": {
    "data_dir": "taiji_data/training_data",
    "tokenizer_path": "taiji/tokenizer_native_v2/sentencepiece.model",
    "contract_path": "taiji/tokenizer_native_v2/tokenizer_contract.json",
    "output_dir": "taiji_checkpoints/taiji_350m",
    "holdout_dir": "taiji_data/training_data/pretrain_12b/holdout",
    "max_steps": 250000,
    "batch_size": 1,
    "gradient_accumulation_steps": 8,
    "learning_rate": 3e-4,
    "min_learning_rate": 3e-5,
    "warmup_steps": 2000,
    "max_length": 2048,
    "save_every": 5000,
    "log_every": 50,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "use_amp": false,
    "use_streaming": true,
    "streaming_buffer": 10000,
    "num_workers": 2,
    "seed": 42,
    "keep_last_checkpoints": 3
  }
}
